# Copy this to .env and fill in your values

# App
SECRET_KEY=replace-with-32-char-random-string
ENVIRONMENT=development
DEBUG=true

# Supabase Postgres
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Redis (local for dev, Upstash for production)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# S3-compatible storage (Cloudflare R2)
S3_ENDPOINT_URL=https://[ACCOUNT_ID].r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=-uploads
S3_REGION=auto

# CORS — add your Vercel URL in production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-app.vercel.app"]

# Sentry (optional)
SENTRY_DSN=
